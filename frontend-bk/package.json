    "react-dom": "18.3.1",
    "react-i18next": "15.4.1",
    "react-markdown": "9.0.3",
    "react-router-dom": "6.30.0",
    "tailwind-merge": "2.5.5",
    "zustand": "5.0.2"
  },
  "devDependencies": {
