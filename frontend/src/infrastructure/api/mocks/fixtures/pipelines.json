      "status": "active",
      "tiers": [
        {
          "tier": "T0",
          "name": "Hotfix",
          "description": "Correções críticas em produção — bypass de gates",
          "color": "#ef4444",
          "criteria": [
            { "id": "crit-t0-1", "field": "labels", "operator": "contains", "value": "hotfix", "description": "Issue contém label 'hotfix'" },
            { "id": "crit-t0-2", "field": "priority", "operator": "equals", "value": "critical", "description": "Prioridade é crítica" }
          ],
          "maxLeadTimeDays": 1,
          "slaHours": 4,
          "autoApproveGates": true
        },
        {
          "tier": "T1",
          "name": "Quick Win",
          "description": "Ajustes simples sem impacto arquitetural",
          "color": "#f59e0b",
          "criteria": [
            { "id": "crit-t1-1", "field": "story_points", "operator": "less_than", "value": "3", "description": "Story points menor que 3" },
            { "id": "crit-t1-2", "field": "components_affected", "operator": "less_than", "value": "2", "description": "Menos de 2 componentes afetados" }
          ],
          "maxLeadTimeDays": 3,
          "slaHours": 24,
          "autoApproveGates": false
        },
        {
          "tier": "T2",
          "name": "Feature",
          "description": "Funcionalidades com escopo definido e impacto moderado",
          "color": "#3b82f6",
          "criteria": [
            { "id": "crit-t2-1", "field": "story_points", "operator": "less_than", "value": "13", "description": "Story points menor que 13" },
            { "id": "crit-t2-2", "field": "has_architectural_impact", "operator": "equals", "value": "false", "description": "Sem impacto arquitetural" }
          ],
          "maxLeadTimeDays": 10,
          "slaHours": 72,
          "autoApproveGates": false
        },
        {
          "tier": "T3",
          "name": "Epic",
          "description": "Entregas complexas, multi-sprint, com impacto arquitetural",
          "color": "#8b5cf6",
          "criteria": [
            { "id": "crit-t3-1", "field": "story_points", "operator": "greater_than", "value": "13", "description": "Story points maior que 13" },
            { "id": "crit-t3-2", "field": "has_architectural_impact", "operator": "equals", "value": "true", "description": "Possui impacto arquitetural" }
          ],
          "maxLeadTimeDays": 30,
          "slaHours": 168,
          "autoApproveGates": false
        }
